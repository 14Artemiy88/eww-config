#!/bin/bash

NET_PATH="/run/user/1000/eww_net"
prev_up=0 prev_down=0
[[ -f "$NET_PATH" ]] && read -r prev_up prev_down < "$NET_PATH"

IFS=$'\t' read -r json new_up new_down < <(
    awk -v p_up="$prev_up" -v p_down="$prev_down" '
    function c(b) {
        if (b < 0) b = 0
        if (b >= 1099511627776) return sprintf("%.2f TB", b / 1099511627776)
        if (b >= 1073741824) return sprintf("%.2f GB", b / 1073741824)
        if (b >= 1048576) return sprintf("%.2f MB", b / 1048576)
        if (b >= 1024) return sprintf("%.2f KB", b / 1024)
        return b " B"
    }
    NR==4 {
        d = $2 + 0; u = $10 + 0
        sd = d - p_down; su = u - p_up
        if (sd < 0) sd = 0; if (su < 0) su = 0
        printf "%s\t%d\t%d\n",
            "{\"down\":\"" c(d) "\",\"up\":\"" c(u) "\",\"speed_down\":\"" c(sd) "\",\"speed_up\":\"" c(su) "\"}",
            u, d
    }
    ' /proc/net/dev
)

printf '%s\n' "$json"
printf '%d %d\n' "$new_up" "$new_down" > "$NET_PATH"
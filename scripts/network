#!/bin/bash

nmcli -g NAME,TYPE,DEVICE c 2>/dev/null | awk -F: '
BEGIN {
    icons["vpn"] = "َ°’ک"
    icons["802-3-ethernet"] = "َ°ˆ€"
    icons["wifi"] = "َ°–©"
    icons["802-11-wireless"] = "ï‡«"
    icons["bluetooth"] = "ïٹ”"
    icons["bridge"] = "َ°،¨"
    icons["tun"] = "َ± ¾"
    icons["wireguard"] = "َ° ¥"
    printf "["
}
$2 != "tun" && $2 != "bridge" && $2 != "loopback" {
    name = $1
    type = $2
    device = $3
    status = device == "" ? "off" : "on"
    icon = (type in icons) ? icons[type] : "ï„¨"
    if (sep) printf ","
    printf "{\"name\":\"%s\",\"type\":\"%s\",\"status\":\"%s\"}", name, icon, status
    sep = 1
}
END { printf "]\n" }'
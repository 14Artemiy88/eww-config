#!/bin/bash

ps -eo pid,pcpu,rss,comm --no-headers | awk '
{
    pid[NR] = $1
    cpu[NR] = $2 + 0
    mem[NR] = $3 + 0
    name[NR] = $4
}
END {
    # Top 5 CPU
    for (i = 1; i <= 5; i++) {
        max = -1; idx = 0
        for (j = 1; j <= NR; j++) {
            if (cpu[j] > max) { max = cpu[j]; idx = j }
        }
        if (max <= 0) break
        cpu_json = cpu_json (i > 1 ? "," : "") \
            "{\"name\":\"" name[idx] "\",\"value\":\"" cpu[idx] "%\",\"pid\":\"" pid[idx] "\"}"
        cpu[idx] = -1
    }

    # Top 5 MEM
    for (i = 1; i <= 5; i++) {
        max = -1; idx = 0
        for (j = 1; j <= NR; j++) {
            if (mem[j] > max) { max = mem[j]; idx = j }
        }
        if (max <= 0) break
        v = mem[idx]
        if (v >= 1000000) v = sprintf("%.1f Gb", v / 1000000)
        else if (v >= 1000) v = sprintf("%.1f Mb", v / 1000)
        else v = v " Kb"
        mem_json = mem_json (i > 1 ? "," : "") \
            "{\"name\":\"" name[idx] "\",\"value\":\"" v "\",\"pid\":\"" pid[idx] "\"}"
        mem[idx] = -1
    }

    print "{\"cpu\":[" cpu_json "],\"mem\":[" mem_json "]}"
}'
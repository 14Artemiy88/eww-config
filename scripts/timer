update_color() {
    local file="$1"
    read_timer_file "$file" || return

    color=$(get_color)
    write_timer_file "$file"
}

comment() {
    local file="$1"
    read_timer_file "$file" || return

    local new_comment
    new_comment=$(kdialog --inputbox "Комментарий" "$comment")

    if [[ $? -eq 0 ]]; then
        comment="$new_comment"
        write_timer_file "$file"
    else
        rm -f "$file"
    fi
}

refresh() {
    local file="$1"
    read_timer_file "$file" || return

    end_time=$(date -d "+$total_time min" +%s)
	  ding=0

    write_timer_file "$file"
}

toggle_pause() {
    local file="$1"
    read_timer_file "$file" || return

    local now
    now=$(date '+%s')
    if (( paused_at == 0 )); then
        # Включаем паузу
        paused_at=$now
    else
        # Выключаем паузу - добавляем прошедшее время к end_time
        local paused_duration=$((now - paused_at))
        end_time=$((end_time + paused_duration))
        paused_at=0
    fi
    write_timer_file "$file"
}

# Главная логика
case "$1" in
    add)          timer_add "$2" "$3";;
    up)           timer_up "$2" ;;
    down)         timer_down "$2" ;;
    delete)       timer_delete "$2" ;;
    update_color) update_color "$2" ;;
    set_color)    set_color "$2" "$3" ;;
    comment)      comment "$2" ;;
    refresh)      refresh "$2" ;;
    toggle_pause) toggle_pause "$2" ;;
    *)            timer ;;
esac

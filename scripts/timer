#!/bin/bash

TIMER_DIR="/run/user/1000/timer"
MESSAGE="динь-динь"

timer() {
    local now timers
    now=$(date '+%s')
    timers=()

    for file in "$TIMER_DIR"/*; do
        [[ -f "$file" ]] || continue

        read_timer_file "$file" || return

        # Если на паузе, используем время начала паузы вместо текущего
        local display_now=$now
        if (( paused_at > 0 )); then
            display_now=$paused_at
        fi

        seconds_left=$((end_time - display_now))

        sign=""
        if (( seconds_left < 0 )); then
            sign=" + "
        fi

        if (( seconds_left <= 0 && ding == 0 )); then
            ding=1
            write_timer_file "$file"
            say "$MESSAGE" &
            kdialog --imgbox ~/Images/D/100-1/50.jpg --title "$total_time мин $comment" &>/dev/null &
        fi

        if [[ -z "$comment" ]]; then
            comment="$total_time"
        fi

        time_passed=$(format_time $((total_time*60 - seconds_left)))

        if (( paused_at > 0 )); then
            timer_str="PAUSED"
        else
            timer_str=$(format_time ${seconds_left#-})
        fi

        timers+=("{\"file\":\"$file\", \"comment\":\"$comment\", \"timer\":\"$timer_str\", \"color\":\"#$color\", \"sign\":\"$sign\", \"time_passed\":\"$time_passed\"}")
    done

    # Формируем JSON через jq для безопасности
    if (( ${#timers[@]} > 0 )); then
        printf '%s\n' "${timers[@]}" | jq -s .
    else
        echo '[]'
    fi
}

timer_up() {
    local file="$1"
    read_timer_file "$file" || return

    end_time=$((end_time + 60))
    local now=$(date '+%s')
    ding=$((end_time - now <= 0))
    total_time=$((total_time + 1))

    write_timer_file "$file"
}

timer_down() {
    local file="$1"
    read_timer_file "$file" || return

    end_time=$((end_time - 60))
    total_time=$((total_time - 1))

    local now=$(date '+%s')
    (( end_time > now )) && write_timer_file "$file"
}

timer_delete() {
    rm -f "$1"
}

timer_add() {
    # Создаем директорию для таймеров, если не существует
    [[ ! -d "$TIMER_DIR" ]] && mkdir -p "$TIMER_DIR"

    local file now
    now=$(date '+%s')
    file="$TIMER_DIR/${now}_$RANDOM"

    echo "$1 $(date -d "+$1 min" +%s ) 0 $(get_color) 0 $2" > "$file"
}

# Функция синтеза речи
say() {
    [[ -n "$1" ]] && echo "$1" | festival --tts --language russian &>/dev/null
}

read_timer_file() {
    local file="$1"
    [[ -f "$file" ]] || return 1
    read -r total_time end_time ding color paused_at comment < "$file"
}

write_timer_file() {
    local file="$1"
    echo "$total_time $end_time $ding $color $paused_at $comment" > "$file" || rm -f "$file"
}

get_color() {
    # Генерируем уникальный цвет с минимальной яркостью
    local hash
    hash=$(printf '%s' "$(date '+%s')$RANDOM" | md5sum | cut -c1-6)
    local r=$((0x${hash:0:2}))
    local g=$((0x${hash:2:2}))
    local b=$((0x${hash:4:2}))

    # Увеличиваем яркость: каждый компонент минимум 96
    (( r < 96 )) && r=$((r + 96))
    (( g < 96 )) && g=$((g + 96))
    (( b < 96 )) && b=$((b + 96))

    # Ограничиваем максимум 255
    (( r > 255 )) && r=255
    (( g > 255 )) && g=255
    (( b > 255 )) && b=255

    printf '%02x%02x%02x' "$r" "$g" "$b"
}

format_time() {
    local total_seconds=$1
    local hours=$((total_seconds / 3600))
    local minutes=$(( (total_seconds % 3600) / 60 ))
    local seconds=$((total_seconds % 60))

    local time_str
    printf -v time_str "%02d:%02d:%02d" $hours $minutes $seconds
    time_str=${time_str##00:} # Удаляем ведущие 00:
    printf '%s\n' "$time_str"
}


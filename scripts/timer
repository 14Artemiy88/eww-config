#!/bin/bash

TIMER_DIR="/run/user/1000/timer"
MESSAGE="динь-динь"

timer() {
    local now timers
    now=$(date '+%s')
    timers=()

    for file in "$TIMER_DIR"/*; do
        [[ -f "$file" ]] || continue

        local end_time ding comment color seconds_left sign
        read -r total_time end_time ding color comment < "$file"

        seconds_left=$((end_time - now))

        sign=""
        if (( seconds_left < 0 )); then
            sign=" + "
        fi

        if (( seconds_left <= 0 && ding == 0 )); then
#            sign=" + "
            echo "$total_time $end_time 1 $color $comment" > "$file"
            say "$MESSAGE"
            kdialog --imgbox ~/Images/D/100-1/50.jpg --title "$total_time мин $comment" &>/dev/null &
        fi

        if [[ -z "$comment" ]]; then
            comment="$total_time"
        fi
	
        # Форматирование времени без вызова date
        seconds_left=${seconds_left#-}
        
        local hours=$((seconds_left / 3600))
        local minutes=$(( (seconds_left % 3600) / 60 ))
        local seconds=$((seconds_left % 60))

        # Форматирование в HH:MM:SS
        local timer_str
        timer_str=$(printf "%02d:%02d:%02d" $hours $minutes $seconds)
        timer_str=${timer_str##00:} # Удаляем ведущие 00:
        timers+=("{\"file\":\"$file\", \"comment\":\"$comment\", \"timer\":\"$timer_str\", \"color\":\"#$color\", \"sign\":\"$sign\"}")
    done

    # Формируем JSON через jq для безопасности
    if (( ${#timers[@]} > 0 )); then
        printf '%s\n' "${timers[@]}" | jq -s .
    else
        echo '[]'
    fi
}

timer_up() {
    local file="$1"
    [[ -f "$file" ]] || return

    local total_time end_time new_time now ding color
    read -r total_time end_time _ color comment < "$file"

    new_time=$((end_time + 60))
    now=$(date '+%s')
    ding=$((new_time - now <= 0))

    echo "$((total_time + 1)) $new_time $ding $color $comment" > "$file"
}

timer_down() {
    local file="$1"
    [[ -f "$file" ]] || return

    local total_time end_time new_time
    read -r total_time end_time _ color comment < "$file"

    new_time=$((end_time - 60))

    (( new_time > $(date '+%s') )) && echo "$((total_time - 1)) $new_time 0 $color $comment" > "$file" || rm -f "$file"
}

timer_delete() {
    rm -f "$1"
}

timer_add() {
  # Создаем директорию для  таймеров, если не существует
  [[ ! -d "$TIMER_DIR" ]] && mkdir -p "$TIMER_DIR"

    local file
    file="$TIMER_DIR/$(date '+%s')"

    echo "$1 $(date -d "+$1 min" +%s ) 0 $(get_color) $2" > "$file"
}

# Функция синтеза речи
say() {
    [[ -n "$1" ]] && echo "$1" | festival --tts --language russian &>/dev/null
}

get_color() {
    printf '%s' "$(date '+%s')" | md5sum | cut -c1-6
}

update_color() {
    local file="$1"
    local end_time sign ding comment
    read -r total_time end_time ding _ comment < "$file"

    echo "$total_time $end_time $ding $(get_color) $comment " > "$file" || rm -f "$file"
}

comment() {
    local file="$1"
    local end_time sign ding comment color
    read -r total_time end_time ding color comment < "$file"

    comment=$(kdialog --inputbox "Комментарий" "$comment")

    echo "$total_time $end_time $ding $color $comment" > "$file" || rm -f "$file"
}

# Главная логика
case "$1" in
    add)          timer_add "$2" "$3";;
    up)           timer_up "$2" ;;
    down)         timer_down "$2" ;;
    delete)       timer_delete "$2" ;;
    update_color) update_color "$2" ;;
    comment)      comment "$2" ;;
    *)            timer ;;
esac

#!/bin/bash

TIMER_DIR="/run/user/1000/timer"
MESSAGE="динь-динь"

timer() {
    local now
    now=$(date '+%s')
    local timers=()

    for file in $(ls -1tr "$TIMER_DIR"/*); do
        [[ -f "$file" ]] || continue

        local end_time sign ding comment
        read -r total_time end_time ding comment < "$file"

        if [[ -z "$comment" ]]; then
            comment="$total_time"
        fi

        local seconds_left=$((end_time - now))
        local sign=""
        if (( seconds_left < 0 )); then
            sign="-"
        fi

        if (( seconds_left <= 0 && ding == 0 )); then
            # rm -f "$file"
            echo "$total_time $end_time 1" > "$file"

            say "$MESSAGE"
            kdialog --imgbox ~/Images/D/100-1/50.jpg --title "$total_time мин $comment" &>/dev/null &


            # continue
        fi

        # Форматирование времени без вызова date
        seconds_left=${seconds_left#-}
        
        local hours=$((seconds_left / 3600))
        local minutes=$(( (seconds_left % 3600) / 60 ))
        local seconds=$((seconds_left % 60))

        # Форматирование в HH:MM:SS
        local timer_str color
        timer_str=$(printf "%02d:%02d:%02d" $hours $minutes $seconds)
        timer_str=${timer_str##00:} # Удаляем ведущие 00:
        timer_str=$(echo "$sign $timer_str")
#        color="#$(printf '%s' "$file" | md5sum | cut -c1-6)"
        color="#$(basename "$file")"
#        timers+=("{\"file\":\"$file\", \"total_time\":\"$total_time\", \"timer\":\"$timer_str\", \"color\":\"$color\", \"comment\":\"$comment\"}")
        timers+=("{\"file\":\"$file\", \"comment\":\"$comment\", \"timer\":\"$timer_str\", \"color\":\"$color\"}")
    done

    # Формируем JSON через jq для безопасности
    if (( ${#timers[@]} > 0 )); then
        printf '%s\n' "${timers[@]}" | jq -s .
    else
        echo '[]'
    fi
}

timer_up() {
    local file="$1"
    [[ -f "$file" ]] || return

    local total_time end_time
    read -r total_time end_time _ comment < "$file"
    echo "$((total_time + 1)) $((end_time + 60)) 0 $comment" > "$file"
}

timer_down() {
    local file="$1"
    [[ -f "$file" ]] || return

    local total_time end_time
    read -r total_time end_time _ comment < "$file"
    local new_time=$((end_time - 60))

    (( new_time > $(date '+%s') )) && echo "$((total_time - 1)) $new_time 0 $comment" > "$file" || rm -f "$file"
}

timer_delete() {
    rm -f "$1"
}

timer_add() {
  # Создаем директорию для  таймеров, если не существует
  [[ ! -d "$TIMER_DIR" ]] && mkdir -p "$TIMER_DIR"

    file="$TIMER_DIR/$(printf '%s' "$(date '+%s')" | md5sum | cut -c1-6)"
    # end=$(date -d "+$1 min" +%s )
    end=$(date -d "+$1 min" +%s )
    echo "$1 $end 0" > "$file"
}

# Функция синтеза речи
say() {
    [[ -n "$1" ]] && echo "$1" | festival --tts --language russian &>/dev/null
}

update_color() {
  mv "$1" "$TIMER_DIR/$(printf '%s' "$(date '+%s')" | md5sum | cut -c1-6)"
}

comment() {

    local file="$1"

    local end_time sign ding comment
    read -r total_time end_time ding comment < "$file"
    comment=$(kdialog --inputbox "Комментарий" "$comment")

    echo "$total_time $end_time $ding $comment" > "$file" || rm -f "$file"
}

# Главная логика
case "$1" in
    add)          timer_add "$2";;
    up)           timer_up "$2" ;;
    down)         timer_down "$2" ;;
    delete)       timer_delete "$2" ;;
    update_color) update_color "$2" ;;
    comment)      comment "$2" ;;
    *)            timer ;;
esac
